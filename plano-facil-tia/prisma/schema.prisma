generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String       @id @default(cuid())
  name                 String
  email                String       @unique
  passwordHash         String?
  googleId             String?      @unique
  role                 Role         @default(PROFESSORA)
  plano                PlanoTipo    @default(TRIAL)
  trialExpiraEm        DateTime     @default(dbgenerated("(now() + '14 days'::interval)"))
  planosNoMes          Int          @default(0)
  planoResetEm         DateTime     @default(dbgenerated("(date_trunc('month'::text, now()) + '1 mon'::interval)"))
  ativo                Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  escolaId             String?
  asaasCustomerId      String?      // ID do cliente na Asaas — NUNCA exposto ao frontend
  asaasSubscriptionId  String?      // ID da assinatura na Asaas — NUNCA exposto ao frontend
  accounts             Account[]
  planos               Plano[]
  escola               Escola?      @relation(fields: [escolaId], references: [id])
  usageLogs            UsageLog[]
  assinatura           Assinatura?
}

model Plano {
  id        String    @id @default(cuid())
  userId    String
  serie     String
  materia   String
  tipo      TipoPlano
  jsonData  Json
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Escola {
  id           String   @id @default(cuid())
  nome         String
  cnpj         String?  @unique
  limiteUsers  Int      @default(10)
  limitePlanos Int      @default(100)
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  users        User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum AssinaturaStatus {
  PENDENTE
  ATIVA
  INADIMPLENTE
  CANCELADA
}

model Assinatura {
  id                   String            @id @default(cuid())
  userId               String            @unique
  asaasSubscriptionId  String            @unique
  status               AssinaturaStatus  @default(PENDENTE)
  metodoPagamento      String            // "CREDIT_CARD" | "PIX"
  valor                Decimal           @db.Decimal(10, 2)
  criadaEm             DateTime          @default(now())
  atualizadaEm         DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id])
}

model WebhookLog {
  id          String   @id @default(cuid())
  evento      String
  payload     Json
  processado  Boolean  @default(false)
  erro        String?
  criadoEm    DateTime @default(now())

  @@index([evento])
  @@index([criadoEm])
}

enum Role {
  PROFESSORA
  ADMIN_ESCOLA
  ADMIN_SISTEMA
}

enum PlanoTipo {
  TRIAL
  PROFESSORA
  ESCOLA
}

enum TipoPlano {
  MENSAL
  AULA_UNICA
}

enum FuncionalidadeTipo {
  GERAR_PLANO
}

model BnccHabilidade {
  id        Int      @id @default(autoincrement())
  codigo    String   @unique
  descricao String
  serie     Int
  area      String
  unidade   String?
  createdAt DateTime @default(now())

  @@index([serie, area])
}

model ConfigLimite {
  id             String             @id @default(cuid())
  planoTipo      PlanoTipo
  funcionalidade FuncionalidadeTipo
  limiteMensal   Int?
  limiteDiario   Int?
  limiteTotal    Int?
  updatedAt      DateTime           @updatedAt

  @@unique([planoTipo, funcionalidade])
}

model UsageLog {
  id             String             @id @default(cuid())
  userId         String
  funcionalidade FuncionalidadeTipo
  mes            Int
  ano            Int
  totalMes       Int                @default(0)
  totalDia       Int                @default(0)
  totalGeral     Int                @default(0)
  ultimoUso      DateTime?
  user           User               @relation(fields: [userId], references: [id])

  @@unique([userId, funcionalidade, mes, ano])
}
